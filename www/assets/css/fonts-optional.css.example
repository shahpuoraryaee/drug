/* OPTIONAL: local fonts. If you download the font files into assets/fonts/,
   rename this file to fonts.css and add
   <link rel="stylesheet" href="assets/css/fonts.css"> to index.php <head>.
   Without it, the app falls back to system fonts and works fine offline. */
@font-face{ font-family:"Bricolage Grotesque"; src:url("../fonts/BricolageGrotesque.woff2") format("woff2"); font-weight:400 700; font-display:swap; }
@font-face{ font-family:"Instrument Sans"; src:url("../fonts/InstrumentSans.woff2") format("woff2"); font-weight:400 700; font-display:swap; }
@font-face{ font-family:"IBM Plex Mono"; src:url("../fonts/IBMPlexMono.woff2") format("woff2"); font-weight:400 600; font-display:swap; }
@font-face{ font-family:"Vazirmatn"; src:url("../fonts/Vazirmatn.woff2") format("woff2"); font-weight:400 700; font-display:swap; }
